{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$(cat /dev/stdin)\" | grep -q 'rm.*spendly.db'; then echo 'BLOCKED: You cannot delete the databse file!' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}